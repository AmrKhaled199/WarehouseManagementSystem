@{
    ViewData["Title"] = "Reports";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 style="font-family:'Syne',sans-serif;font-weight:700;margin:0">
            <i data-lucide="bar-chart-2" style="width:22px;height:22px;margin-right:8px;color:#f59e0b;vertical-align:middle"></i>Reports
        </h4>
        <p style="color:var(--text-secondary);font-size:13px;margin:2px 0 0 30px">Export data to Excel</p>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i data-lucide="calendar" style="width:15px;height:15px;margin-right:6px"></i>Filter by Month
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Month</label>
                <select id="month" class="form-select">
                    <option value="">All Months</option>
                    <option value="1">January</option>
                    <option value="2">February</option>
                    <option value="3">March</option>
                    <option value="4">April</option>
                    <option value="5">May</option>
                    <option value="6">June</option>
                    <option value="7">July</option>
                    <option value="8">August</option>
                    <option value="9">September</option>
                    <option value="10">October</option>
                    <option value="11">November</option>
                    <option value="12">December</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Year</label>
                <select id="year" class="form-select">
                    <option value="2024">2024</option>
                    <option value="2025">2025</option>
                    <option value="2026" selected>2026</option>
                    <option value="2027">2027</option>
                </select>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="action-card" style="cursor:default">
            <span class="action-icon">
                <i data-lucide="package" style="width:32px;height:32px;color:#4f8ef7"></i>
            </span>
            <div class="action-title">Products Report</div>
            <div class="action-desc mb-3">All products in warehouse</div>
            <button onclick="download('Products')" class="btn btn-primary w-100">
                <i data-lucide="download" style="width:14px;height:14px;margin-right:5px"></i>Download Excel
            </button>
        </div>
    </div>

    <div class="col-md-4">
        <div class="action-card" style="cursor:default">
            <span class="action-icon">
                <i data-lucide="dollar-sign" style="width:32px;height:32px;color:#22c55e"></i>
            </span>
            <div class="action-title">Storage Fees Report</div>
            <div class="action-desc mb-3">Storage fees summary</div>
            <button onclick="download('StorageFees')" class="btn btn-success w-100">
                <i data-lucide="download" style="width:14px;height:14px;margin-right:5px"></i>Download Excel
            </button>
        </div>
    </div>

    <div class="col-md-4">
        <div class="action-card" style="cursor:default">
            <span class="action-icon">
                <i data-lucide="bell" style="width:32px;height:32px;color:#38bdf8"></i>
            </span>
            <div class="action-title">Logs Report</div>
            <div class="action-desc mb-3">All notifications log</div>
            <button onclick="download('Logs')" class="btn btn-danger w-100">
                <i data-lucide="download" style="width:14px;height:14px;margin-right:5px"></i>Download Excel
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function download(type) {
            var month = document.getElementById('month').value;
            var year = document.getElementById('year').value;
            var url = '/Report/Download' + type;
            if (month) {
                url += '?month=' + month + '&year=' + year;
            }
            window.location.href = url;
        }
    </script>
}
