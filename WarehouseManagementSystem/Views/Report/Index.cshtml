@{
    ViewData["Title"] = "Reports";
}

<div class="container mt-4">
    <h4 class="mb-4">📊 Excel Reports</h4>

    <!-- Filter -->
    <div class="card shadow mb-4">
        <div class="card-header bg-dark text-white">
            <h6 class="mb-0">📅 Filter by Month</h6>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Month</label>
                    <select id="month" class="form-select">
                        <option value="">All Months</option>
                        <option value="1">January</option>
                        <option value="2">February</option>
                        <option value="3">March</option>
                        <option value="4">April</option>
                        <option value="5">May</option>
                        <option value="6">June</option>
                        <option value="7">July</option>
                        <option value="8">August</option>
                        <option value="9">September</option>
                        <option value="10">October</option>
                        <option value="11">November</option>
                        <option value="12">December</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Year</label>
                    <select id="year" class="form-select">
                        <option value="2024">2024</option>
                        <option value="2025">2025</option>
                        <option value="2026" selected>2026</option>
                        <option value="2027">2027</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Report Cards -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow text-center p-4">
                <h2>📦</h2>
                <h5>Products Report</h5>
                <p class="text-muted">All products in warehouse</p>
                <button onclick="download('Products')" class="btn btn-primary">
                    ⬇️ Download Excel
                </button>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow text-center p-4">
                <h2>💰</h2>
                <h5>Storage Fees Report</h5>
                <p class="text-muted">Storage fees summary</p>
                <button onclick="download('StorageFees')" class="btn btn-success">
                    ⬇️ Download Excel
                </button>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow text-center p-4">
                <h2>📋</h2>
                <h5>Logs Report</h5>
                <p class="text-muted">All notifications log</p>
                <button onclick="download('Logs')" class="btn btn-danger">
                    ⬇️ Download Excel
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function download(type) {
            var month = document.getElementById('month').value;
            var year = document.getElementById('year').value;
            var url = '/Report/Download' + type;
            if (month) {
                url += '?month=' + month + '&year=' + year;
            }
            window.location.href = url;
        }
    </script>
}