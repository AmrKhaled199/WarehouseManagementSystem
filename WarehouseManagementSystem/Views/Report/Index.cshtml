@{
    ViewData["Title"] = "Reports";
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <title>Reports</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark px-4">
        <span class="navbar-brand">🏭 WMS</span>
        <div class="d-flex gap-3">
            <a href="/Home/Index" class="btn btn-outline-light btn-sm">🏠 Home</a>
            <a href="/Account/Logout" class="btn btn-outline-danger btn-sm">Exit</a>
        </div>
    </nav>

    <div class="container mt-5">
        <h4 class="mb-4">📊 Excel Reports</h4>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card shadow text-center p-4">
                    <h2>📦</h2>
                    <h5>Products Report</h5>
                    <p class="text-muted">كل المنتجات في المستودع</p>
                    <a href="/Report/DownloadProducts" class="btn btn-primary">
                        ⬇️ Download Excel
                    </a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow text-center p-4">
                    <h2>💰</h2>
                    <h5>Storage Fees Report</h5>
                    <p class="text-muted">تقرير التكاليف والرسوم</p>
                    <a href="/Report/DownloadStorageFees" class="btn btn-success">
                        ⬇️ Download Excel
                    </a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow text-center p-4">
                    <h2>📋</h2>
                    <h5>Logs Report</h5>
                    <p class="text-muted">سجل كل الإشعارات</p>
                    <a href="/Report/DownloadLogs" class="btn btn-danger">
                        ⬇️ Download Excel    
                    </a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>