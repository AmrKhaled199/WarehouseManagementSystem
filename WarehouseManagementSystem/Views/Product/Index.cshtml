@model IEnumerable<WMS.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 style="font-family:'Syne',sans-serif;font-weight:700;margin:0">
            <i data-lucide="boxes" style="width:22px;height:22px;margin-right:8px;color:#4f8ef7;vertical-align:middle"></i>Products
        </h4>
        <p style="color:var(--text-secondary);font-size:13px;margin:2px 0 0 30px">Inventory management</p>
    </div>
    <a href="/Product/Add" class="btn btn-primary">
        <i data-lucide="package-plus" style="width:15px;height:15px;margin-right:6px"></i>Add Product
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="stat-card">
            <div class="stat-label">
                <i data-lucide="package" style="width:13px;height:13px;margin-right:5px"></i>Total Products
            </div>
            <div class="stat-value">@ViewBag.TotalCount</div>
            <div class="stat-unit">of 1,000 max capacity</div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="stat-card">
            <div class="stat-label">
                <i data-lucide="scale" style="width:13px;height:13px;margin-right:5px"></i>Total Weight
            </div>
            <div class="stat-value">@ViewBag.TotalWeight</div>
            <div class="stat-unit">kg — of 3,000 kg max</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span>
            <i data-lucide="list" style="width:15px;height:15px;margin-right:6px"></i>Products List
        </span>
        <span class="badge bg-secondary">@Model.Count() items</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5" style="color:var(--text-muted)">
                <i data-lucide="package-open" style="width:48px;height:48px;margin-bottom:12px;opacity:0.4"></i>
                <p>No products in warehouse yet.</p>
                <a href="/Product/Add" class="btn btn-primary btn-sm">Add First Product</a>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Weight (kg)</th>
                        <th>Status</th>
                        <th>Entry Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td style="color:var(--text-muted)">@p.Id</td>
                            <td style="font-weight:500">@p.Name</td>
                            <td>@p.Category</td>
                            <td>@p.WeightKg</td>
                            <td>
                                @if (p.Status == "InWarehouse")
                                {
                                    <span class="badge bg-success">
                                        <i data-lucide="check-circle" style="width:11px;height:11px;margin-right:3px"></i>In Warehouse
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        <i data-lucide="truck" style="width:11px;height:11px;margin-right:3px"></i>Delivered
                                    </span>
                                }
                            </td>
                            <td style="color:var(--text-secondary)">@p.EntryDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="d-flex gap-1 flex-wrap">
                                    <a href="/Product/Details/@p.Id" class="btn btn-sm btn-info">
                                        <i data-lucide="eye" style="width:13px;height:13px;margin-right:3px"></i>Details
                                    </a>

                                    @if (p.Status == "InWarehouse")
                                    {
                                        <form method="post" action="/Product/Deliver/@p.Id" style="display:inline">
                                            <button type="submit" class="btn btn-warning btn-sm"
                                                    onclick="return confirm('Confirm delivery?')">
                                                <i data-lucide="truck" style="width:13px;height:13px;margin-right:3px"></i>Deliver
                                            </button>
                                        </form>
                                    }

                                    @if (Context.Session.GetString("UserRole") == "Admin")
                                    {
                                        <form method="post" action="/Product/Delete/@p.Id" style="display:inline">
                                            <button type="submit" class="btn btn-danger btn-sm"
                                                    onclick="return confirm('Are you sure you want to delete?')">
                                                <i data-lucide="trash-2" style="width:13px;height:13px;margin-right:3px"></i>Delete
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
