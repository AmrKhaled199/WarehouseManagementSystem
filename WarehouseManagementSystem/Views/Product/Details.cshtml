@model WMS.Models.Product
@{
    ViewData["Title"] = "Product Details";
    var invoiceNum = "WMS-" + Model.Id.ToString("D5");
}

<style>
    .print-header { display: none; }
    .info-box-value { font-weight: 700 !important; color: #e8eaf0 !important; font-size: 15px !important; }
</style>

<div class="d-flex align-items-center justify-content-between mb-4 no-print">
    <div>
        <h4 style="font-family:'Syne',sans-serif;font-weight:700;margin:0">
            <i data-lucide="search" style="width:22px;height:22px;margin-right:8px;color:#38bdf8;vertical-align:middle"></i>Product Details
        </h4>
        <p style="color:var(--text-secondary);font-size:13px;margin:2px 0 0 30px">@Model.Name</p>
    </div>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-info">
            <i data-lucide="printer" style="width:15px;height:15px;margin-right:5px"></i>Print Invoice
        </button>
        <a href="/Product/Index" class="btn btn-dark">
            <i data-lucide="arrow-left" style="width:14px;height:14px;margin-right:4px"></i>Back
        </a>
    </div>
</div>

<div class="print-header">
    <div class="inv-top">
        <div>
            <div class="inv-brand">Khaled Family <span>WMS</span></div>
            <div class="inv-brand-sub">Warehouse Management System</div>
        </div>
        <div>
            <div class="inv-num-label">Invoice No.</div>
            <div class="inv-num">@invoiceNum</div>
            <div class="inv-date">@DateTime.Now.ToString("dd MMM yyyy, HH:mm")</div>
        </div>
    </div>

    <div class="inv-title-row">
        <div class="inv-product-name">@Model.Name</div>
        @if (Model.Status == "InWarehouse")
        {
            <span class="inv-badge inv-badge-blue">In Warehouse</span>
        }
        else
        {
            <span class="inv-badge inv-badge-green">Delivered</span>
        }
    </div>

    <div class="inv-grid4">
        <div class="inv-box">
            <div class="inv-box-label">Category</div>
            <div class="inv-box-value">@Model.Category</div>
        </div>
        <div class="inv-box">
            <div class="inv-box-label">Weight</div>
            <div class="inv-box-value">@Model.WeightKg kg</div>
        </div>
        <div class="inv-box">
            <div class="inv-box-label">Entry Date</div>
            <div class="inv-box-value">@Model.EntryDate.ToString("dd/MM/yyyy")</div>
        </div>
        <div class="inv-box">
            <div class="inv-box-label">Expiry Date</div>
            <div class="inv-box-value" class="info-box-value">@Model.ExpiryDate.ToString("dd/MM/yyyy")</div>
        </div>
    </div>

    <div class="inv-section">Contact Information</div>
    <div class="inv-contact-grid">
        <div class="inv-contact">
            <div class="inv-contact-role">Sender</div>
            <div class="inv-contact-name">@Model.SenderName</div>
            <div class="inv-contact-email">@Model.SenderEmail</div>
        </div>
        <div class="inv-contact">
            <div class="inv-contact-role">Receiver</div>
            <div class="inv-contact-name">@Model.ReceiverName</div>
            <div class="inv-contact-email">@Model.ReceiverEmail</div>
        </div>
    </div>

    @if (Model.ExitDate.HasValue)
    {
        <div class="inv-section" style="margin-top:16px">Delivery</div>
        <div class="inv-grid2">
            <div class="inv-box">
                <div class="inv-box-label">Exit Date</div>
                <div class="inv-box-value">@Model.ExitDate.Value.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            <div class="inv-box">
                <div class="inv-box-label">Storage Duration</div>
                <div class="inv-box-value">@((Model.ExitDate.Value - Model.EntryDate).Days) days</div>
            </div>
        </div>
    }

    @if (ViewBag.StorageFee != null)
    {
        <div class="inv-fee">
            <div class="inv-fee-title">Storage Fee Summary</div>
            <div class="inv-fee-row">
                <span>Rate</span>
                <span>@ViewBag.StorageFee.RatePerHourPerKg $ / hour / kg</span>
            </div>
            <div class="inv-fee-row">
                <span>Weight</span>
                <span>@Model.WeightKg kg</span>
            </div>
            <div class="inv-fee-row">
                <span>Calculated At</span>
                <span>@ViewBag.StorageFee.CalculatedAt.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="inv-fee-row">
                <span class="inv-fee-total">Total Amount Due</span>
                <span class="inv-fee-amount">$@ViewBag.StorageFee.TotalFee</span>
            </div>
        </div>
    }

    <div class="inv-footer">
        <div class="inv-footer-note">
            Generated automatically by Khaled Family WMS<br />
            @DateTime.Now.ToString("dd/MM/yyyy HH:mm") — @invoiceNum
        </div>
        <div class="inv-stamp">Khaled Family WMS</div>
    </div>
</div>

<div class="card mx-auto no-print" style="max-width:680px">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span>
            <i data-lucide="package" style="width:15px;height:15px;margin-right:6px"></i>@Model.Name
        </span>
        @if (Model.Status == "InWarehouse")
        {
            <span class="badge bg-success">
                <i data-lucide="check-circle" style="width:11px;height:11px;margin-right:3px"></i>In Warehouse
            </span>
        }
        else
        {
            <span class="badge bg-secondary">
                <i data-lucide="truck" style="width:11px;height:11px;margin-right:3px"></i>Delivered
            </span>
        }
    </div>
    <div class="card-body">
        <div class="row g-3 mb-4">
            <div class="col-6">
                <div style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-md);padding:1rem">
                    <div style="font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-secondary);margin-bottom:4px">Category</div>
                    <div style="font-weight:600;color:var(--text-primary)">@Model.Category</div>
                </div>
            </div>
            <div class="col-6">
                <div style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-md);padding:1rem">
                    <div style="font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-secondary);margin-bottom:4px">Weight</div>
                    <div style="font-weight:600;color:var(--text-primary)">@Model.WeightKg kg</div>
                </div>
            </div>
            <div class="col-6">
                <div style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-md);padding:1rem">
                    <div style="font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-secondary);margin-bottom:4px">Entry Date</div>
                    <div style="font-weight:600" class="info-box-value">@Model.EntryDate.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
            </div>
            <div class="col-6">
                <div style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-md);padding:1rem">
                    <div style="font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-secondary);margin-bottom:4px">Expiry Date</div>
                    <div style="font-weight:600" class="info-box-value">@Model.ExpiryDate.ToString("dd/MM/yyyy")</div>
                </div>
            </div>
        </div>

        <table class="table mb-0">
            <tbody>
                <tr>
                    <td style="color:var(--text-secondary);width:140px;font-size:13px">
                        <i data-lucide="send" style="width:13px;height:13px;margin-right:4px"></i>Sender
                    </td>
                    <td>@Model.SenderName <span style="color:var(--text-muted);font-size:13px">(@Model.SenderEmail)</span></td>
                </tr>
                <tr>
                    <td style="color:var(--text-secondary);font-size:13px">
                        <i data-lucide="user" style="width:13px;height:13px;margin-right:4px"></i>Receiver
                    </td>
                    <td>@Model.ReceiverName <span style="color:var(--text-muted);font-size:13px">(@Model.ReceiverEmail)</span></td>
                </tr>
                <tr>
                    <td style="color:var(--text-secondary);font-size:13px">
                        <i data-lucide="calendar" style="width:13px;height:13px;margin-right:4px"></i>Exit Date
                    </td>
                    <td>
                        @if (Model.ExitDate.HasValue)
                        {
                            @Model.ExitDate.Value.ToString("dd/MM/yyyy HH:mm")
                        }
                        else
                        {
                            <span style="color:var(--text-muted)">Still in warehouse</span>
                        }
                    </td>
                </tr>
                <tr>
                    <td style="color:var(--text-secondary);font-size:13px">
                        <i data-lucide="dollar-sign" style="width:13px;height:13px;margin-right:4px"></i>Storage Fee
                    </td>
                    <td style="font-weight:600;color:var(--warning)">@ViewBag.StorageFee?.TotalFee $</td>
                </tr>
            </tbody>
        </table>

        @if (ViewBag.StorageFee != null)
        {
            <div class="alert alert-warning mt-3">
                <div style="font-size:13px;font-weight:600;margin-bottom:8px">
                    <i data-lucide="calculator" style="width:14px;height:14px;margin-right:5px"></i>Storage Fee Details
                </div>
                <table class="table table-sm mb-0" style="font-size:13px">
                    <tr>
                        <td style="color:var(--text-secondary);width:120px">Rate</td>
                        <td>@ViewBag.StorageFee.RatePerHourPerKg $ / hour / kg</td>
                    </tr>
                    <tr>
                        <td style="color:var(--text-secondary)">Total Fee</td>
                        <td><strong>$@ViewBag.StorageFee.TotalFee</strong></td>
                    </tr>
                    <tr>
                        <td style="color:var(--text-secondary)">Calculated At</td>
                        <td>@ViewBag.StorageFee.CalculatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                </table>
            </div>
        }

        <div class="d-flex gap-2 mt-4 flex-wrap">
            @if (Model.Status == "InWarehouse")
            {
                <form method="post" action="/Product/Deliver/@Model.Id">
                    <button type="submit" class="btn btn-warning" onclick="return confirm('Confirm delivery?')">
                        <i data-lucide="check-circle" style="width:15px;height:15px;margin-right:5px"></i>Mark as Delivered
                    </button>
                </form>
            }
            <button onclick="window.print()" class="btn btn-info">
                <i data-lucide="printer" style="width:15px;height:15px;margin-right:5px"></i>Print Invoice
            </button>
            @if (Context.Session.GetString("UserRole") == "Admin")
            {
                <form method="post" action="/Product/Delete/@Model.Id">
                    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure?')">
                        <i data-lucide="trash-2" style="width:15px;height:15px;margin-right:5px"></i>Delete
                    </button>
                </form>
            }
        </div>
    </div>
</div>
