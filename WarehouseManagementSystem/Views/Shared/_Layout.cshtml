<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Khaled Family WMS</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/wms-dark.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;700&display=swap" rel="stylesheet" />
</head>
<body>

    <nav class="navbar">
        <a class="navbar-brand" href="/Home/Index" style="display:flex;align-items:center;gap:10px;text-decoration:none;">
            <svg width="36" height="36" viewBox="0 0 58 60" xmlns="http://www.w3.org/2000/svg">
                <polygon points="29,2 55,17 55,47 29,62 3,47 3,17" fill="none" stroke="#2055c7" stroke-width="1.5" />
                <polygon points="29,10 49,22 49,46 29,58 9,46 9,22" fill="#0d1b3e" />
                <rect x="14" y="26" width="5" height="14" rx="1.5" fill="#2055c7" />
                <rect x="26.5" y="21" width="5" height="19" rx="1.5" fill="#6B9EFF" />
                <rect x="39" y="26" width="5" height="14" rx="1.5" fill="#2055c7" />
                <line x1="14" y1="40" x2="44" y2="40" stroke="#6B9EFF" stroke-width="0.8" opacity="0.5" />
                <polygon points="29,16 33,21 29,26 25,21" fill="#6B9EFF" />
                <circle cx="55" cy="17" r="2.5" fill="#2055c7" />
                <circle cx="3" cy="17" r="2.5" fill="#2055c7" />
                <circle cx="29" cy="2" r="2.5" fill="#6B9EFF" />
            </svg>
            <span style="font-family:'Outfit',sans-serif;font-weight:700;font-size:16px;color:#dce8ff;line-height:1;">
                Khaled Family <span style="color:#6B9EFF;">WMS</span>
            </span>
        </a>
        <div class="d-flex align-items-center gap-2">
            @if (Context.Session.GetString("UserName") != null)
            {
                <span style="display:flex;align-items:center;gap:7px;margin-right:6px;padding:4px 12px;background:rgba(107,158,255,0.08);border:1px solid rgba(107,158,255,0.2);border-radius:20px;">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#6B9EFF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="8" r="4" />
                        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                    </svg>
                    <span style="font-size:12px;font-weight:600;color:#c8d8ff;letter-spacing:.3px">@Context.Session.GetString("UserName")</span>
                </span>
                <a href="/Product/Add" class="btn btn-sm">
                    <i data-lucide="package-plus" style="width:14px;height:14px;margin-right:4px"></i>Import
                </a>
                <a href="/Product/Index" class="btn btn-sm">
                    <i data-lucide="boxes" style="width:14px;height:14px;margin-right:4px"></i>Products
                </a>
                <a href="/Report/Index" class="btn btn-sm">
                    <i data-lucide="bar-chart-2" style="width:14px;height:14px;margin-right:4px"></i>Reports
                </a>
                <a href="/Log/Index" class="btn btn-sm">
                    <i data-lucide="bell" style="width:14px;height:14px;margin-right:4px"></i>Logs
                </a>
                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <a href="/User/Index" class="btn btn-sm">
                        <i data-lucide="users" style="width:14px;height:14px;margin-right:4px"></i>Users
                    </a>
                }
                <a href="/Account/Logout" class="btn btn-sm btn-outline-danger">
                    <i data-lucide="log-out" style="width:14px;height:14px;margin-right:4px"></i>Exit
                </a>
            }
        </div>
        <!-- Hamburger -->
        <button class="nav-hamburger" onclick="toggleMobileMenu()" aria-label="Menu">
            <svg id="ham-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <line x1="3" y1="6" x2="21" y2="6" />
                <line x1="3" y1="12" x2="21" y2="12" />
                <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
        </button>
    </nav>

    <!-- Mobile Menu -->
    <div class="nav-mobile-menu" id="mobileMenu">
        @if (Context.Session.GetString("UserName") != null)
        {
            <div class="user-pill">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6B9EFF" stroke-width="2.5" stroke-linecap="round">
                    <circle cx="12" cy="8" r="4" />
                    <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                </svg>
                @Context.Session.GetString("UserName")
            </div>
            <a href="/Product/Add" class="btn btn-sm">
                <i data-lucide="package-plus" style="width:14px;height:14px;margin-right:8px"></i>Import
            </a>
            <a href="/Product/Index" class="btn btn-sm">
                <i data-lucide="boxes" style="width:14px;height:14px;margin-right:8px"></i>Products
            </a>
            <a href="/Report/Index" class="btn btn-sm">
                <i data-lucide="bar-chart-2" style="width:14px;height:14px;margin-right:8px"></i>Reports
            </a>
            <a href="/Log/Index" class="btn btn-sm">
                <i data-lucide="bell" style="width:14px;height:14px;margin-right:8px"></i>Logs
            </a>
            @if (Context.Session.GetString("UserRole") == "Admin")
            {
                <a href="/User/Index" class="btn btn-sm">
                    <i data-lucide="users" style="width:14px;height:14px;margin-right:8px"></i>Users
                </a>
            }
            <a href="/Account/Logout" class="btn btn-sm btn-outline-danger">
                <i data-lucide="log-out" style="width:14px;height:14px;margin-right:8px"></i>Exit
            </a>
        }
    </div>

    <script>
            function toggleMobileMenu() {
                const menu = document.getElementById('mobileMenu');
                menu.classList.toggle('open');
            }
            // Close menu on outside click
            document.addEventListener('click', function(e) {
                const menu = document.getElementById('mobileMenu');
                const btn = document.querySelector('.nav-hamburger');
                if (!menu.contains(e.target) && !btn.contains(e.target)) {
                    menu.classList.remove('open');
                }
            });
    </script>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer>
        WMS — Khaled Family &copy; 2026
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <script>lucide.createIcons();</script>

</body>
</html>
