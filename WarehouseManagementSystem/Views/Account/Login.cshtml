@model WarehouseManagementSystem.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WMS — Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700&family=DM+Sans:wght@300;400;500&family=Outfit:wght@300;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #0a0c10; --surface: #111318; --elevated: #181b22;
            --accent: #4f8ef7; --accent-glow: rgba(79,142,247,0.15);
            --border: #1f2330; --border-light: #2a2f3e;
            --text: #e8eaf0; --muted: #4a4f60; --secondary: #8b90a0;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-wrap { width: 100%; max-width: 400px; padding: 1rem; }
        .brand { text-align: center; margin-bottom: 2rem; }
        .brand-icon { width: 48px; height: 48px; background: var(--accent-glow); border: 1px solid rgba(79,142,247,0.3); border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; font-size: 22px; margin-bottom: 12px; }
        .brand h1 { font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 700; color: var(--text); }
        .brand p { font-size: 13px; color: var(--secondary); margin-top: 4px; }
        .card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; }
        .form-label { font-size: 12px; font-weight: 500; color: var(--secondary); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; display: block; }
        .form-control { background: var(--elevated); border: 1px solid var(--border-light); color: var(--text); border-radius: 8px; padding: 10px 14px; font-size: 14px; width: 100%; transition: border-color .18s, box-shadow .18s; }
        .form-control:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); background: var(--elevated); color: var(--text); }
        .form-control::placeholder { color: var(--muted); }
        .mb-3 { margin-bottom: 1rem; }
        .btn-login { width: 100%; background: var(--accent); color: #fff; border: none; border-radius: 8px; padding: 11px; font-size: 14px; font-weight: 500; cursor: pointer; margin-top: 0.5rem; transition: all .18s; }
        .btn-login:hover { background: #3a7be8; box-shadow: 0 0 20px rgba(79,142,247,0.3); }
        .text-danger { color: #ef4444 !important; font-size: 12px; margin-top: 4px; display: block; }
        .alert-danger { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); color: #ef4444; border-radius: 8px; padding: 10px 14px; font-size: 13px; margin-bottom: 1rem; }
        .link-row { text-align: center; margin-top: 1.2rem; font-size: 13px; color: var(--secondary); }
        .link-row a { color: var(--accent); text-decoration: none; }
        .link-row a:hover { text-decoration: underline; }
        .divider { border: none; border-top: 1px solid var(--border); margin: 1.5rem 0; }
    </style>
</head>
<body>
<div class="login-wrap">
    <div class="brand">
        <svg width="72" height="72" viewBox="0 0 58 60" xmlns="http://www.w3.org/2000/svg" style="margin-bottom:14px;"><polygon points="29,2 55,17 55,47 29,62 3,47 3,17" fill="none" stroke="#2055c7" stroke-width="1.5"/><polygon points="29,10 49,22 49,46 29,58 9,46 9,22" fill="#0d1b3e"/><rect x="14" y="26" width="5" height="14" rx="1.5" fill="#2055c7"/><rect x="26.5" y="21" width="5" height="19" rx="1.5" fill="#6B9EFF"/><rect x="39" y="26" width="5" height="14" rx="1.5" fill="#2055c7"/><line x1="14" y1="40" x2="44" y2="40" stroke="#6B9EFF" stroke-width="0.8" opacity="0.5"/><polygon points="29,16 33,21 29,26 25,21" fill="#6B9EFF"/><circle cx="55" cy="17" r="2.5" fill="#2055c7"/><circle cx="3" cy="17" r="2.5" fill="#2055c7"/><circle cx="29" cy="2" r="2.5" fill="#6B9EFF"/></svg>
        <h1 style="font-family:'Outfit',sans-serif;font-weight:700;">Khaled Family <span style="color:#6B9EFF;">WMS</span></h1>
        <p>Warehouse Management System</p>
    </div>
    <div class="card">
        <form asp-controller="Account" asp-action="Login" method="post">
            <div asp-validation-summary="All" class="alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <button type="submit" class="btn-login">Sign In →</button>
        </form>
        <hr class="divider" />
        <div class="link-row">
            Don't have an account? <a asp-action="Register">Create one</a>
        </div>
    </div>
</div>
</body>
</html>
