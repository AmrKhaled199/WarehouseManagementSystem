@{
    ViewData["Title"] = "Dashboard";
}

<div class="welcome-banner">
    <h4>👋 Welcome back, @ViewBag.UserName</h4>
    <p>Logged in as <strong style="color:#4f8ef7">@ViewBag.UserRole</strong> — Khaled Family Warehouse</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="stat-card">
            <div class="stat-label">
                <i data-lucide="package" style="width:13px;height:13px;margin-right:5px"></i>Products in Warehouse
            </div>
            <div class="stat-value">@ViewBag.TotalCount</div>
            <div class="stat-unit">of 1,000 max capacity</div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="stat-card">
            <div class="stat-label">
                <i data-lucide="scale" style="width:13px;height:13px;margin-right:5px"></i>Total Weight
            </div>
            <div class="stat-value">@ViewBag.TotalWeight</div>
            <div class="stat-unit">kg — of 3,000 kg max</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-3">
        <a href="/Product/Index" class="action-card">
            <span class="action-icon">
                <i data-lucide="boxes" style="width:32px;height:32px;color:#4f8ef7"></i>
            </span>
            <div class="action-title">Products</div>
            <div class="action-desc">Inventory management</div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/Product/Add" class="action-card">
            <span class="action-icon">
                <i data-lucide="package-plus" style="width:32px;height:32px;color:#22c55e"></i>
            </span>
            <div class="action-title">Import</div>
            <div class="action-desc">Receive new goods</div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/Report/Index" class="action-card">
            <span class="action-icon">
                <i data-lucide="bar-chart-2" style="width:32px;height:32px;color:#f59e0b"></i>
            </span>
            <div class="action-title">Reports</div>
            <div class="action-desc">Excel exports</div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/Log/Index" class="action-card">
            <span class="action-icon">
                <i data-lucide="bell" style="width:32px;height:32px;color:#38bdf8"></i>
            </span>
            <div class="action-title">Logs</div>
            <div class="action-desc">Notification history</div>
        </a>
    </div>
</div>
