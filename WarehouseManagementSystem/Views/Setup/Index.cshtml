@{
    ViewData["Title"] = "First Time Setup";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WMS Setup</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #0a0c10; --surface: #111318; --elevated: #181b22;
            --accent: #4f8ef7; --accent-glow: rgba(79,142,247,0.15);
            --border: #1f2330; --border-light: #2a2f3e;
            --text: #e8eaf0; --muted: #4a4f60; --secondary: #8b90a0;
            --success: #22c55e;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .setup-wrap { width: 100%; max-width: 460px; padding: 1rem; }
        .brand { text-align: center; margin-bottom: 2rem; }
        .brand-icon { width: 56px; height: 56px; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); border-radius: 14px; display: inline-flex; align-items: center; justify-content: center; font-size: 26px; margin-bottom: 12px; }
        .step-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.25); border-radius: 20px; padding: 4px 12px; font-size: 12px; color: var(--success); margin-bottom: 12px; }
        .brand h1 { font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 700; color: var(--text); }
        .brand p { font-size: 13px; color: var(--secondary); margin-top: 4px; }
        .card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; }
        .form-label { font-size: 12px; font-weight: 500; color: var(--secondary); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; display: block; }
        .form-control { background: var(--elevated); border: 1px solid var(--border-light); color: var(--text); border-radius: 8px; padding: 10px 14px; font-size: 14px; width: 100%; transition: border-color .18s, box-shadow .18s; }
        .form-control:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); background: var(--elevated); color: var(--text); }
        .form-control::placeholder { color: var(--muted); }
        .mb-3 { margin-bottom: 1rem; }
        .btn-setup { width: 100%; background: var(--success); color: #fff; border: none; border-radius: 8px; padding: 12px; font-size: 14px; font-weight: 600; cursor: pointer; margin-top: 0.5rem; transition: all .18s; letter-spacing: 0.02em; }
        .btn-setup:hover { background: #16a34a; box-shadow: 0 0 24px rgba(34,197,94,0.25); }
        .alert-danger { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); color: #ef4444; border-radius: 8px; padding: 10px 14px; font-size: 13px; margin-bottom: 1rem; }
        .alert-info { background: rgba(56,189,248,0.08); border: 1px solid rgba(56,189,248,0.2); color: #38bdf8; border-radius: 8px; padding: 10px 14px; font-size: 13px; margin-bottom: 1.2rem; }
        .footer-note { text-align: center; color: var(--muted); font-size: 12px; margin-top: 1.2rem; }
    </style>
</head>
<body>
<div class="setup-wrap">
    <div class="brand">
        <div class="step-badge">⚙️ First Time Setup</div>
        <div class="brand-icon">🏭</div>
        <h1>Khaled Family WMS</h1>
        <p>Create your Admin account to get started</p>
    </div>
    <div class="card">
        @if (ViewBag.Error != null)
        {
            <div class="alert-danger">❌ @ViewBag.Error</div>
        }

        <div class="alert-info">
            <strong>Welcome!</strong> No admin account found. Set up your credentials below.
        </div>

        <form method="post">
            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input type="text" name="fullName" class="form-control" placeholder="e.g. Amr Khaled" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" placeholder="admin@example.com" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" placeholder="Min. 6 characters" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Confirm Password</label>
                <input type="password" name="confirmPassword" class="form-control" placeholder="Repeat password" required />
            </div>
            <button type="submit" class="btn-setup">🚀 Create Admin & Get Started</button>
        </form>
    </div>
    <p class="footer-note">This page only appears once — when no admin exists.</p>
</div>
</body>
</html>
